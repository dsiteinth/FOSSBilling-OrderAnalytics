{% block js %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
<script>
    // ─── Chart Instances ───
    let revenueChartInstance = null;
    let categoryChartInstance = null;
    let paymentMethodsChartInstance = null;

    // ─── Chart.js Global Config ───
    Chart.defaults.font.family = "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif";
    Chart.defaults.font.size = 12;
    Chart.defaults.color = '#6c757d';
    Chart.defaults.plugins.legend.display = false;

    // ─── Global Filter State ───
    let currentFilter = {
        start_date: '',
        end_date: '',
        exclude_pending: false,
        category_id: 'all'
    };

    // ─── Initializer ───
    document.addEventListener('DOMContentLoaded', function() {
        setDefaultDates();
        loadCategoryFilter();
        applyFilters();
    });

    function loadCategoryFilter() {
        FOSSBilling.api.admin.post('product/category_get_pairs', {}, function(result) {
            const select = document.getElementById('category-filter');
            for (const [id, title] of Object.entries(result)) {
                const option = document.createElement('option');
                option.value = id;
                option.textContent = title;
                select.appendChild(option);
            }
        });
    }

    // ─── Date Helpers ───
    function setDefaultDates() {
        // Set default to last 30 days
        const end = new Date();
        const start = new Date();
        start.setDate(end.getDate() - 29); // 30 days including today

        document.getElementById('start_date').value = formatDateForInput(start);
        document.getElementById('end_date').value = formatDateForInput(end);
    }

    function formatDateForInput(date) {
        const d = new Date(date);
        let month = '' + (d.getMonth() + 1);
        let day = '' + d.getDate();
        const year = d.getFullYear();

        if (month.length < 2) month = '0' + month;
        if (day.length < 2) day = '0' + day;

        return [year, month, day].join('-');
    }

    function formatDateDisplay(dateStr) {
        if (!dateStr) return '';
        const d = new Date(dateStr);
        return d.toLocaleDateString(undefined, { day: 'numeric', month: 'short', year: 'numeric' });
    }

    function onPresetChange() {
        const preset = document.getElementById('date-range-preset').value;
        const customContainer = document.getElementById('custom-date-container');
        
        if (preset === 'custom') {
            customContainer.classList.remove('d-none');
            customContainer.classList.add('d-flex');
            return;
        } else {
            customContainer.classList.add('d-none');
            customContainer.classList.remove('d-flex');
        }

        let end = new Date();
        let start = new Date();

        switch (preset) {
            case 'today':
                break; // start and end are today
            case 'last_7_days':
                start.setDate(end.getDate() - 6);
                break;
            case 'last_30_days':
                start.setDate(end.getDate() - 29);
                break;
            case 'this_month':
                start = new Date(end.getFullYear(), end.getMonth(), 1);
                break;
            case 'last_month':
                start = new Date(end.getFullYear(), end.getMonth() - 1, 1);
                end = new Date(end.getFullYear(), end.getMonth(), 0);
                break;
            case 'this_year':
                start = new Date(end.getFullYear(), 0, 1);
                break;
        }

        document.getElementById('start_date').value = formatDateForInput(start);
        document.getElementById('end_date').value = formatDateForInput(end);
        applyFilters();
    }

    function applyFilters() {
        const start = document.getElementById('start_date').value;
        const end = document.getElementById('end_date').value;
        const excludePending = document.getElementById('exclude_pending').checked;
        const categoryId = document.getElementById('category-filter').value;
        
        if (!start || !end) {
            FOSSBilling.message('Please select a valid date range', 'error');
            return;
        }
        
        if (new Date(start) > new Date(end)) {
            FOSSBilling.message('Start date cannot be after end date', 'error');
            return;
        }

        currentFilter = { 
            start_date: start, 
            end_date: end, 
            exclude_pending: excludePending,
            category_id: categoryId
        };
        
        // Update label
        document.getElementById('current-period-label').innerHTML = 
            'Showing: <strong>' + formatDateDisplay(start) + ' - ' + formatDateDisplay(end) + '</strong>';

        refreshAllData();
    }

    function refreshAllData() {
        loadSummary();
        loadRevenueStats();
        loadRevenueChart();
        loadCategoryChart();
        loadPaymentMethodsChart();
        loadTopProducts();
        loadTopClients();
        loadRecentOrders();
    }

    // ─── Formatters ───
    function formatCurrency(value) {
        return parseFloat(value).toLocaleString(undefined, {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
        });
    }

    function renderGrowthBadge(elementId, growth) {
        const el = document.getElementById(elementId);
        if (!el) return;
        
        if (growth > 0) {
            el.className = 'growth-badge growth-up';
            el.innerHTML = '↑ ' + growth + '% vs prev';
        } else if (growth < 0) {
            el.className = 'growth-badge growth-down';
            el.innerHTML = '↓ ' + Math.abs(growth) + '% vs prev';
        } else {
            el.className = 'growth-badge growth-neutral';
            el.innerHTML = '→ 0% vs prev';
        }
    }

    function getStatusBadge(status) {
        const map = {
            'active': '<span class="status-badge bg-success-lt text-success">Active</span>',
            'pending_setup': '<span class="status-badge bg-warning-lt text-warning">Pending</span>',
            'suspended': '<span class="status-badge bg-secondary-lt text-secondary">Suspended</span>',
            'canceled': '<span class="status-badge bg-danger-lt text-danger">Canceled</span>',
            'failed_setup': '<span class="status-badge bg-purple-lt text-purple">Failed</span>',
            'failed_renew': '<span class="status-badge bg-orange-lt text-orange">Failed</span>',
        };
        return map[status] || '<span class="status-badge bg-secondary-lt">' + status + '</span>';
    }

    function getRankClass(index) {
        if (index === 0) return 'top-1';
        if (index === 1) return 'top-2';
        if (index === 2) return 'top-3';
        return '';
    }

    // ─── Data Loaders ───
    function loadSummary() {
        FOSSBilling.api.admin.post('orderanalytics/get_summary', currentFilter, function(result) {
            document.getElementById('stat-total-orders').textContent = result.total;
            document.getElementById('stat-active-orders').textContent = result.active;
            
            renderGrowthBadge('stat-growth-total-orders', result.total_growth);
            renderGrowthBadge('stat-growth-active-orders', result.active_growth);
        });
    }

    function loadRevenueStats() {
        FOSSBilling.api.admin.post('orderanalytics/get_revenue_stats', currentFilter, function(result) {
            document.getElementById('stat-revenue').textContent = formatCurrency(result.total);
            document.getElementById('stat-refunds').textContent = formatCurrency(result.refunds);
            document.getElementById('stat-aov').textContent = formatCurrency(result.aov);

            renderGrowthBadge('stat-growth-revenue', result.growth);
            renderGrowthBadge('stat-growth-refunds', result.refunds_growth);
            renderGrowthBadge('stat-growth-aov', result.aov_growth);
        });
    }

    function loadRevenueChart() {
        FOSSBilling.api.admin.post('orderanalytics/get_revenue_chart', currentFilter, function(result) {
            const ctx = document.getElementById('revenueChart').getContext('2d');

            if (revenueChartInstance) {
                revenueChartInstance.destroy();
            }

            const gradient = ctx.createLinearGradient(0, 0, 0, 320);
            gradient.addColorStop(0, 'rgba(32, 107, 196, 0.15)');
            gradient.addColorStop(1, 'rgba(32, 107, 196, 0.01)');

            revenueChartInstance = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: result.labels,
                    datasets: [{
                        label: '{{ "Current Period"|trans }}',
                        data: result.data,
                        borderColor: '#206bc4',
                        backgroundColor: gradient,
                        borderWidth: 2.5,
                        fill: true,
                        tension: 0.4,
                        pointBackgroundColor: '#206bc4',
                        pointBorderColor: '#fff',
                        pointBorderWidth: 2,
                        pointRadius: 3,
                        pointHoverRadius: 6
                    }, {
                        label: '{{ "Previous Period"|trans }}',
                        data: result.prev_data,
                        borderColor: '#adb5bd',
                        borderWidth: 2,
                        borderDash: [5, 5],
                        fill: false,
                        tension: 0.4,
                        pointBackgroundColor: '#adb5bd',
                        pointBorderColor: '#fff',
                        pointBorderWidth: 2,
                        pointRadius: 0,
                        pointHoverRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: { mode: 'index', intersect: false },
                    scales: {
                        x: { grid: { display: false }, ticks: { maxTicksLimit: 12 } },
                        y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.04)' }, ticks: { callback: formatCurrency } }
                    },
                    plugins: {
                        legend: { display: true, position: 'top', align: 'end', labels: { usePointStyle: true, boxWidth: 8 } },
                        tooltip: { padding: 12, callbacks: { label: (ctx) => ctx.dataset.label + ': ' + formatCurrency(ctx.parsed.y) } }
                    }
                }
            });
        });
    }

    function loadCategoryChart() {
        FOSSBilling.api.admin.post('orderanalytics/get_category_distribution', currentFilter, function(result) {
            const ctx = document.getElementById('categoryChart').getContext('2d');
            if (categoryChartInstance) categoryChartInstance.destroy();

            categoryChartInstance = new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: result.labels,
                    datasets: [{
                        data: result.data,
                        backgroundColor: result.colors,
                        borderWidth: 0,
                        hoverOffset: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '70%',
                    plugins: {
                        legend: { display: true, position: 'bottom', labels: { usePointStyle: true, boxWidth: 8 } }
                    }
                }
            });
        });
    }

    function loadPaymentMethodsChart() {
        FOSSBilling.api.admin.post('orderanalytics/get_payment_methods', currentFilter, function(result) {
            const ctx = document.getElementById('paymentMethodsChart').getContext('2d');
            if (paymentMethodsChartInstance) paymentMethodsChartInstance.destroy();

            paymentMethodsChartInstance = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: result.labels,
                    datasets: [{
                        data: result.data,
                        backgroundColor: '#ae3ec9',
                        borderRadius: 4
                    }]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        x: { beginAtZero: true, grid: { display: false }, ticks: { stepSize: 1 } },
                        y: { grid: { display: false } }
                    }
                }
            });
        });
    }

    function loadTopProducts() {
        const payload = Object.assign({}, currentFilter, { limit: 5 });
        FOSSBilling.api.admin.post('orderanalytics/get_top_products', payload, function(result) {
            const tbody = document.querySelector('#table-top-products tbody');
            tbody.innerHTML = '';
            
            if (result.length === 0) {
                tbody.innerHTML = '<tr><td colspan="4" class="text-center py-4 text-secondary">No data</td></tr>';
                return;
            }

            result.forEach((item, index) => {
                const tr = document.createElement('tr');
                const categoryHtml = item.category_title ? `<div class="small text-secondary">${item.category_title}</div>` : '';
                tr.innerHTML = `
                    <td class="text-center"><span class="rank-number ${getRankClass(index)}">${index + 1}</span></td>
                    <td>
                        <div class="fw-medium">${item.product_title}</div>
                        ${categoryHtml}
                    </td>
                    <td class="text-center">${item.order_count}</td>
                    <td class="text-end fw-bold">${formatCurrency(item.total_revenue)}</td>
                `;
                tbody.appendChild(tr);
            });
        });
    }

    function loadTopClients() {
        const payload = Object.assign({}, currentFilter, { limit: 5 });
        FOSSBilling.api.admin.post('orderanalytics/get_top_clients', payload, function(result) {
            const tbody = document.querySelector('#table-top-clients tbody');
            tbody.innerHTML = '';
            
            if (result.length === 0) {
                tbody.innerHTML = '<tr><td colspan="4" class="text-center py-4 text-secondary">No data</td></tr>';
                return;
            }

            result.forEach((item, index) => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td class="text-center"><span class="rank-number ${getRankClass(index)}">${index + 1}</span></td>
                    <td>
                        <div class="fw-medium">
                            <a href="{{ 'client/manage'|url({ 'admin': 1 }) }}/${item.client_id}" class="text-body">${item.client_name}</a>
                        </div>
                        <div class="small text-secondary">${item.client_email}</div>
                    </td>
                    <td class="text-center">${item.order_count}</td>
                    <td class="text-end fw-bold text-success">${formatCurrency(item.total_spent)}</td>
                `;
                tbody.appendChild(tr);
            });
        });
    }

    function loadRecentOrders() {
        const payload = Object.assign({}, currentFilter, { limit: 10 });
        FOSSBilling.api.admin.post('orderanalytics/get_recent_orders', payload, function(result) {
            const tbody = document.querySelector('#table-recent-orders tbody');
            tbody.innerHTML = '';

            if (result.length === 0) {
                tbody.innerHTML = '<tr><td colspan="6" class="text-center py-4 text-secondary">No orders found in this period</td></tr>';
                return;
            }

            result.forEach(order => {
                const tr = document.createElement('tr');
                const date = formatDateDisplay(order.created_at);
                tr.innerHTML = `
                    <td><a href="{{ 'order/manage'|url({ 'admin': 1 }) }}/${order.id}" class="fw-medium">#${order.id}</a></td>
                    <td>${order.title} <div class="small text-secondary">${order.period}</div></td>
                    <td>${order.client_name}</td>
                    <td class="text-center">${getStatusBadge(order.status)}</td>
                    <td class="text-end">${formatCurrency(order.price)}</td>
                    <td class="text-secondary">${date}</td>
                `;
                tbody.appendChild(tr);
            });
        });
    }

    // ─── CSV Export ───
    function exportDashboardToCSV() {
        FOSSBilling.api.admin.post('orderanalytics/get_recent_orders', Object.assign({}, currentFilter, {limit: 500}), function(result) {
            if (!result || result.length === 0) {
                FOSSBilling.message('No data to export', 'warning');
                return;
            }
            
            const headers = ['Order ID', 'Product', 'Status', 'Price', 'Period', 'Client Name', 'Client Email', 'Date'];
            let csvContent = headers.join(',') + '\n';
            
            result.forEach(row => {
                const values = [
                    row.id,
                    `"${row.title.replace(/"/g, '""')}"`,
                    row.status,
                    row.price,
                    row.period,
                    `"${row.client_name.replace(/"/g, '""')}"`,
                    `"${row.client_email}"`,
                    row.created_at
                ];
                csvContent += values.join(',') + '\n';
            });
            
            const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
            const url = URL.createObjectURL(blob);
            const link = document.createElement("a");
            link.setAttribute("href", url);
            link.setAttribute("download", "OrderAnalytics_Export_" + currentFilter.start_date + "_to_" + currentFilter.end_date + ".csv");
            link.style.visibility = 'hidden';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            
            FOSSBilling.message('Export completed');
        });
    }
</script>
{% endblock %}
