{% extends request.ajax ? 'layout_blank.html.twig' : 'layout_default.html.twig' %}

{% import 'macro_functions.html.twig' as mf %}

{% set active_menu = 'order' %}

{% block meta_title %}{{ 'Order Analytics'|trans }}{% endblock %}

{% block breadcrumbs %}
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="{{ '/'|url({ 'admin': 1 }) }}">{{ 'Home'|trans }}</a>
        </li>
        <li class="breadcrumb-item">
            <a href="{{ 'order'|url({ 'admin': 1 }) }}">{{ 'Orders'|trans }}</a>
        </li>
        <li class="breadcrumb-item active">{{ 'Order Analytics'|trans }}</li>
    </ol>
{% endblock %}

{% block content %}

{# ─── INLINE STYLES for analytics dashboard ─── #}
<style>
    .analytics-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border: none;
        border-radius: 8px;
        height: 100%;
    }
    .analytics-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
    }
    .stat-value {
        font-size: 1.75rem;
        font-weight: 700;
        line-height: 1.2;
    }
    .stat-label {
        font-size: 0.8125rem;
        color: #6c757d;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-weight: 600;
    }
    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .stat-icon svg {
        width: 24px;
        height: 24px;
    }
    .growth-badge {
        font-size: 0.75rem;
        font-weight: 600;
        padding: 3px 8px;
        border-radius: 20px;
        display: inline-flex;
        align-items: center;
        margin-top: 5px;
    }
    .growth-up {
        background: rgba(47, 179, 68, 0.1);
        color: #2fb344;
    }
    .growth-down {
        background: rgba(214, 57, 57, 0.1);
        color: #d63939;
    }
    .growth-neutral {
        background: rgba(108, 117, 125, 0.1);
        color: #6c757d;
    }
    .chart-container {
        position: relative;
        height: 320px;
        width: 100%;
    }
    .chart-container-sm {
        position: relative;
        height: 260px;
        width: 100%;
    }
    .table-analytics th {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #6c757d;
        font-weight: 600;
        border-bottom: 2px solid #e0e5ec;
    }
    .table-analytics td {
        vertical-align: middle;
        padding: 10px 12px;
    }
    .status-badge {
        font-size: 0.75rem;
        padding: 3px 10px;
        border-radius: 20px;
        font-weight: 600;
    }
    .section-title {
        font-size: 1rem;
        font-weight: 700;
        margin: 0;
    }
    .card-analytics {
        border: none;
        border-radius: 8px;
        box-shadow: 0 1px 4px rgba(0, 0, 0, 0.06);
    }
    .rank-number {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: #f0f4f8;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        font-weight: 700;
        color: #6c757d;
    }
    .rank-number.top-1 { background: #fff3bf; color: #e67700; }
    .rank-number.top-2 { background: #e9ecef; color: #495057; }
    .rank-number.top-3 { background: #ffe3cc; color: #d9480f; }

    .loading-spinner {
        display: inline-block;
        width: 20px;
        height: 20px;
        border: 2px solid #e0e5ec;
        border-radius: 50%;
        border-top-color: #206bc4;
        animation: spin 0.6s linear infinite;
    }
    @keyframes spin {
        to { transform: rotate(360deg); }
    }
    .fade-in {
        animation: fadeIn 0.4s ease-out;
    }
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(8px); }
        to { opacity: 1; transform: translateY(0); }
    }
    
    /* Utility for flex */
    .gap-2 { gap: 0.5rem; }
    .gap-3 { gap: 1rem; }
</style>

{# ─── PAGE HEADER & FILTER BAR ─── #}
<div class="d-flex align-items-center justify-content-between mb-3 fade-in">
    <div>
        <h2 class="page-title mb-1">
            <svg class="icon me-2" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="20" x2="18" y2="10"></line>
                <line x1="12" y1="20" x2="12" y2="4"></line>
                <line x1="6" y1="20" x2="6" y2="14"></line>
            </svg>
            {{ 'Order Analytics'|trans }}
        </h2>
        <p class="text-secondary mb-0">{{ 'Comprehensive overview of your sales performance and order data.'|trans }}</p>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-secondary" onclick="exportDashboardToCSV()">
            <svg class="icon me-1" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            {{ 'Export CSV'|trans }}
        </button>
    </div>
</div>

{# ─── FILTER BAR ─── #}
<div class="card mb-4 fade-in">
    <div class="card-body d-flex flex-wrap justify-content-between align-items-center py-3">
        <div class="d-flex align-items-center flex-wrap gap-2">
            <label class="form-label mb-0 fw-bold">{{ 'Category'|trans }}:</label>
            <select id="category-filter" class="form-select w-auto" onchange="applyFilters()">
                <option value="all">{{ 'All Categories'|trans }}</option>
            </select>

            <label class="form-label mb-0 fw-bold ms-2">{{ 'Date Range'|trans }}:</label>
            <select id="date-range-preset" class="form-select w-auto" onchange="onPresetChange()">
                <option value="today">{{ 'Today'|trans }}</option>
                <option value="last_7_days">{{ 'Last 7 Days'|trans }}</option>
                <option value="last_30_days" selected>{{ 'Last 30 Days'|trans }}</option>
                <option value="this_month">{{ 'This Month'|trans }}</option>
                <option value="last_month">{{ 'Last Month'|trans }}</option>
                <option value="this_year">{{ 'This Year'|trans }}</option>
                <option value="custom">{{ 'Custom Range'|trans }}</option>
            </select>
            <div id="custom-date-container" class="d-none align-items-center gap-2">
                <input type="date" id="start_date" class="form-control" onchange="applyFilters()" />
                <span class="text-secondary">to</span>
                <input type="date" id="end_date" class="form-control" onchange="applyFilters()" />
            </div>
            <div class="form-check form-switch mb-0 ms-2">
                <input class="form-check-input" type="checkbox" id="exclude_pending" onchange="applyFilters()">
                <label class="form-check-label pt-1" for="exclude_pending">{{ 'Exclude Pending'|trans }}</label>
            </div>
        </div>
        <div class="text-secondary small mt-2 mt-md-0" id="current-period-label">
            <!-- Populated by JS -->
        </div>
    </div>
</div>

